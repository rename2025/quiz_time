# Django
SECRET_KEY=your-super-secret-key-change-this
DEBUG=0
ALLOWED_HOSTS=localhost,127.0.0.1,yourdemin.com

# Database
DB_NAME=quizdb
DB_USER=quizuser
DB_PASSWORD=quizpass...
DB_HOST=postgres
DB_PORT=5432

# Redis

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redispass...

# Email
EMAIL_HOST=smtp.gmail.com
EMALI_PORT=587
EMLAL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=1

# AW S3 for backup
AWS_ACCESS_KEY_ID=you-aws-secret
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_STORAGE_BUCKET_NAME=quiz-backups
AWS_S3_REGION_NAME=us-east-1

# Sentry
SENTRY_DSN=your-sentry-dsn

# Admin
ADMIN_URL=admin/
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin-pass...

